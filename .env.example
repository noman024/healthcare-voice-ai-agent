# Monorepo root — no secrets here.
#
# Copy templates (gitignored targets may hold machine-specific values):
#   cd backend && python3 -m venv .venv && source .venv/bin/activate
#   pip install -r requirements.txt
#   cp .env.example .env
#
#   cd ../frontend && cp .env.local.example .env.local
#
# Voice pipeline (optional):
#   • FastAPI (backend): HTTP, SQLite, /tools, /stt, /tts, GET /livekit/token
#   • LiveKit signal server: docker compose -f docker-compose.livekit.yml up
#   • Worker: pip install -r requirements-livekit.txt; optionally
#     PYTHONPATH=. python scripts/run_voice_worker.py download-files
#     then PYTHONPATH=. python scripts/run_voice_worker.py
#   • Frontend: NEXT_PUBLIC_LIVEKIT_URL + NEXT_PUBLIC_LIVEKIT_DEFAULT_ROOM (optional NEXT_PUBLIC_LIVEKIT_DIAG,
#     NEXT_PUBLIC_LIVEKIT_AGENT_WAIT_MS — see frontend/.env.local.example).
#   • Backend/worker (Piper ↔ RoomIO): VOICE_PUBLISH_SAMPLE_RATE=24000 in backend/.env (matches resampled TTS).
#
# See backend/.env.example and frontend/.env.local.example for full variable lists.
