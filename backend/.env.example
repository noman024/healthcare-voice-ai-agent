# =============================================================================
# Copy to `backend/.env` (gitignored). Run uvicorn with cwd = `backend/`.
# =============================================================================

# --- Core
APP_ENV=development
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Relative DB path resolves against process CWD — use `backend/` or an absolute path
DATABASE_PATH=data/appointments.db

# --- Feature flags
# 1 = add informational cost_hints on POST /agent/summary
INCLUDE_COST_HINTS=0
# Dev-only: GET /internal/db/snapshot (never enable on public internet)
ENABLE_DB_INSPECT=0
# 1 = persist dialogue to SQLite (`conversation_messages`) for summaries across restarts
CONVERSATION_PERSIST=0
# Optional positive int: SQLite hydrate fetches at most N×2 rows (user+assistant); see conversation_messages.py
# CONVERSATION_PERSIST_MAX_MESSAGES=10
# 0/false = skip Whisper + Ollama + Piper warmup at startup (good for pytest)
WARMUP_MODELS=1

# --- Logging (repo root logs/voice-agent-api.log)
LOG_ENABLED=1
LOG_LEVEL=INFO
LOG_UVICORN=0
# LOG_MAX_BYTES=10485760
# LOG_BACKUP_COUNT=4

# --- Appointment slot template (fetch_slots)
SLOT_OPEN_HOUR=9
SLOT_CLOSE_HOUR=17
SLOT_STEP_MINUTES=30

# --- Phone normalization (spoken numbers without country code)
# 880 / bd — Bangladesh 01[3-9]… → +880 | 44 / uk — UK 07… → +44 (default when unset)
# PHONE_DEFAULT_CC=

# --- Ollama (LLM)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b-instruct
# Optional per-pass overrides (default: OLLAMA_MODEL for each)
# OLLAMA_PLANNER_MODEL=qwen2.5:7b-instruct
# OLLAMA_FINALIZE_MODEL=qwen2.5:7b-instruct
# OLLAMA_SUMMARY_MODEL=qwen2.5:7b-instruct
OLLAMA_REQUEST_TIMEOUT_S=300
OLLAMA_INFER_DEVICE=auto
OLLAMA_NUM_GPU_LAYERS=-1
# OLLAMA_OPTIONS_JSON={"num_ctx":4096}

# --- Piper TTS
PIPER_BINARY=<REPO_ROOT>/.tools/piper/piper/piper
PIPER_VOICE=<REPO_ROOT>/.tools/piper/voices/en_US-lessac-low.onnx
PIPER_LD_LIBRARY_PATH=
PIPER_TIMEOUT_SEC=120
PIPER_CUDA=auto
PIPER_CUDA_STRATEGY=all
PIPER_CUDA_CPU_FALLBACK=1
# Piper --length_scale: values <1 speed speech (e.g. 0.92); >1 slow (e.g. 1.1). Omit = Piper default (~1).
# PIPER_LENGTH_SCALE=0.92
# Piper --sentence_silence (seconds between sentences; default ~0.2). Lower feels snappier on long replies.
# PIPER_SENTENCE_SILENCE=0.12

# --- CUDA (Whisper / Piper LD path preload)
# Auto-discovery adds pip nvidia/*/lib, CONDA_PREFIX, /usr/local/cuda, etc. — see cuda_ld_path.py
# For libcublas issues: pip install -r requirements-whisper-gpu.txt
CUDA_HOME=
CUDA_LIBRARY_PATH=
# CONDA_PREFIX is set by Conda — no need to copy here

# --- faster-whisper (STT)
# tiny|base|small|… — latency vs accuracy; matches faster-whisper model id
WHISPER_MODEL=base
# auto|cuda|cpu — cuda uses GPU when CTranslate2 reports devices
WHISPER_DEVICE=cuda
# Comma-separated GPU indices, e.g. 0 or 0,1 (empty = all visible)
WHISPER_DEVICE_INDICES=
# float16 (GPU default) or int8 (CPU default / override)
WHISPER_COMPUTE_TYPE=
WHISPER_BEAM_SIZE=5
# 1 = VAD pre-filter (fewer hallucinations on noise)
WHISPER_VAD_FILTER=0
WHISPER_NUM_WORKERS=
WHISPER_MAX_WORKERS=8
WHISPER_CPU_NUM_WORKERS=1

# --- LiveKit + livekit-agents voice worker (optional)
#
# FastAPI remains the single HTTP surface: appointments, GET /livekit/token, POST /tts, POST /stt,
# POST /tools/invoke, WebSockets, etc. The worker (``scripts/run_voice_worker.py``) joins LiveKit
# rooms, runs VAD → faster-whisper (same stack as POST /stt) → Ollama via OpenAI-compatible
# plugin → Piper via POST /tts; tools execute against the same SQLite file as the API.
#
# Setup: ``source .venv/bin/activate`` then ``pip install -r requirements-livekit.txt``
# Worker: ``PYTHONPATH=. python scripts/run_voice_worker.py`` (cwd = backend/)
# Silero / plugin models (first run): ``PYTHONPATH=. python scripts/run_voice_worker.py download-files``
# Worker reuses ``OLLAMA_*`` / ``OLLAMA_MODEL`` from this file when both processes run on the same host.
#
# LIVEKIT_* must match your signal server (``docker-compose.livekit.yml --dev`` prints keys in logs).
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=ws://127.0.0.1:7880
#
# URL of this FastAPI app as reachable from the worker (TTS calls ``$VOICE_API_BASE/tts``).
VOICE_API_BASE=http://127.0.0.1:8000
# Shared secret for ``POST /internal/voice/worker/transcript`` (worker mirrors chat lines to SQLite for summaries).
# Set the **same** value in ``backend/.env`` for both FastAPI and the worker process.
# VOICE_INTERNAL_SECRET=
# PCM rate published to LiveKit RoomIO; worker resamples Piper WAV to this Hz (matches livekit-agents default).
VOICE_PUBLISH_SAMPLE_RATE=24000
# Worker: ``HealthcareVoiceAgent`` runs Piper once per assistant reply. Stock LiveKit ``Agent`` would call TTS per sentence (StreamAdapter + sentence tokenizer).
# LiveKit worker: Silero VAD endpointing, worker-only Whisper beam, MuseTalk WAV chunk size (tune latency vs accuracy).
VOICE_LIVEKIT_VAD_MIN_SILENCE=0.35
VOICE_LIVEKIT_VAD_PREFIX_PADDING=0.22
# VOICE_LIVEKIT_VAD_MIN_SPEECH=0.05
# VOICE_LIVEKIT_VAD_ACTIVATION_THRESHOLD=0.5
# Beam search depth for worker STT only (REST still uses WHISPER_BEAM_SIZE).
VOICE_LIVEKIT_WHISPER_BEAM=3
# Bytes per ``tts_wav_chunk`` after ``tts_begin`` (larger ⇒ fewer publish_data calls).
VOICE_TTS_UI_CHUNK_BYTES=24000
# 1 = log STT vs agent (LLM+tools) vs Piper TTS ms per /ws/conversation_audio turn (server log).
# VOICE_WS_PIPELINE_TIMING=1
# 0/false = single full-utterance TTS + one MuseTalk job (smoothest LiveKit lipsync + room audio).
# 1 = sentence-scale segments (faster first audio when worker lipsync off; with worker lipsync on, omit
#     this var to default to 0 — chunked MuseTalk causes visible pauses between sentences).
# Explicit 1 forces segmentation even when VOICE_WORKER_LIPSYNC=1 (chunked avatar).
# VOICE_TTS_SEGMENTED=1
# Segment length cap (40–600 chars); default 180
# VOICE_TTS_MAX_SEGMENT_CHARS=180
# 1 = worker POSTs /avatar/lipsync immediately after Piper; streams MP4 on topic ``va`` (browser skips its own lipsync POST).
VOICE_WORKER_LIPSYNC=1
# When VOICE_WORKER_LIPSYNC=1: 1 (default) = finish streaming MP4 + **all** ``tts_wav_chunk`` payloads on ``va`` before emitting room PCM (browser can start MP4 + align with chunk WAV before speakers play; avoids whole turn heard then lipsync). 0 = start WAV chunks and room audio in parallel with MuseTalk (lower latency, possible skew).
VOICE_LIPSYNC_BEFORE_ROOM_AUDIO=1
# Lip-sync debugging without the browser (REST / WS / sample ``va`` payloads): ``python scripts/simulate_lipsync_paths.py --help``
# VOICE_WORKER_LIPSYNC_TIMEOUT_SEC=300
# 1 = align assistant captions with TTS timing (karaoke-style). Omit or 0 = show text as soon as generated (default behavior).
# VOICE_SYNC_TRANSCRIPTION_TO_AUDIO=1
#
# Worker process log level (optional)
WORKER_LOG_LEVEL=INFO

# --- MuseTalk video lipsync (optional, GPU)
# Run the **dedicated** process on port 8001 (GPU / heavy deps) and point the main API at it:
#   cd backend && uvicorn app.musetalk.service_app:app --host 0.0.0.0 --port 8001
# Main API (8000) forwards /avatar/lipsync* when MUSETALK_SERVICE_URL is set; omit it to run
# MuseTalk in the same process as uvicorn (not recommended for production).
# MUSETALK_SERVICE_URL=http://127.0.0.1:8001
# MUSETALK_PROXY_TIMEOUT_SEC=300
# Uses ``third_party/MuseTalk`` (clone from GitHub) with weights from HuggingFace (see upstream README).
# Prefer a **separate** Python venv for MuseTorch deps: set MUSETALK_PYTHON to that interpreter.
# 1 = MuseTalk service exposes POST /avatar/lipsync; main app forwards if MUSETALK_SERVICE_URL set.
# 1 = on the MuseTalk **service** process (.env is shared); main app does not require MUSETALK_ENABLED for proxy-only.
MUSETALK_ENABLED=0
# MUSETALK_PYTHON=/path/to/musetalk-venv/bin/python
MUSETALK_ROOT=../third_party/MuseTalk
MUSETALK_REFERENCE_IMAGE=assets/musetalk/reference.jpg
MUSETALK_CACHE_DIR=.musetalk_cache
# Directory containing the ``ffmpeg`` executable (or run: bash backend/scripts/setup_ffmpeg_static.sh)
# MUSETALK_FFMPEG_PATH=third_party/ffmpeg-static/current
# Lipsync: CUDA device indices (comma-separated, round-robin). Default uses GPUs 0–3 when present.
# On a single-GPU machine use MUSETALK_GPU_IDS=0 (or leave unset and set MUSETALK_GPU_ID=0).
# To follow torch.cuda.device_count() instead of a fixed list, comment out GPU_IDS and set MUSETALK_USE_ALL_GPUS=1.
MUSETALK_GPU_IDS=0,1,2,3
# MUSETALK_GPU_ID=0
# MUSETALK_USE_ALL_GPUS=1
MUSETALK_TIMEOUT_SEC=240
MUSETALK_FLOAT16=1
# MuseTalk model bundle id passed to upstream inference (default v15)
# MUSETALK_VERSION=v15
# Frames per UNet batch (8 is a sensible default; reduce on OOM; sweep with ``scripts/benchmark_musetalk.py``).
MUSETALK_BATCH_SIZE=8
# 1 = set TORCH_CUDNN_BENCHMARK in the MuseTalk subprocess (often speeds convs after warmup).
MUSETALK_TORCH_CUDNN_BENCHMARK=1
# Faster libx264 encode for PNG→MP4 (after UNet). Comment both out to use MuseTalk script defaults (preset medium, CRF 18).
MUSETALK_X264_PRESET=veryfast
MUSETALK_X264_CRF=20
# 1 = log ``musetalk_latency`` + ``musetalk_http`` breakdown (enable on the MuseTalk service / :8001 process).
# MUSETALK_TIMING_LOG=1
# MUSETALK_FPS=25
# 1 = one inference per GPU at a time; after face coord .pkl exists, jobs no longer global-serialize on reference (multi-GPU parallel).
# MUSETALK_SINGLE_FLIGHT=1
# On MuseTalk service only: run one dummy lip-sync at startup so the first real request is faster (loads Torch/Whisper once).
# MUSETALK_WARMUP_ON_START=1
# Face coord cache ``{MUSETALK_CACHE_DIR}/<reference_stem>.pkl`` must persist between requests; do not delete it in production.
# If image-only inference fails on a fresh MuseTalk clone, run: python scripts/fix_musetalk_inference_image.py

# --- Shell scripts (e2e_integration_real.sh, e2e_real_smoke.sh, benchmark_api_performance.py)
# API_BASE=http://127.0.0.1:8000
