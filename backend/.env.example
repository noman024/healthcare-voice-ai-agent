# =============================================================================
# Backend — copy this file to `.env` and edit paths/values for your machine.
# File `.env` is gitignored — never commit it.
#
# Safety after cloning or rotating credentials:
#   • If `.env` (or secrets) ever reached git history, revoke/rotate LiveKit/API keys at
#     the issuer and replace locally; rewrite history only if policy requires it.
#   • Keep every secret only in `.env`, shell export, or a secrets manager — not in README
#     or chat logs tied to this repo.
# Values below are non-sensitive defaults or empty placeholders unless noted.
# =============================================================================

APP_ENV=development

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DATABASE_PATH=data/appointments.db

# Persist rolling transcripts to SQLite (`conversation_messages` table). Default 0 keeps memory in-process only.
# CONVERSATION_PERSIST=0
# CONVERSATION_PERSIST_MAX_MESSAGES=20

WARMUP_MODELS=1

# Rotating logs at repo root logs/voice-agent-api.log — attached to logging namespace "app" (see log_setup.py)
LOG_ENABLED=1
LOG_LEVEL=INFO
LOG_UVICORN=0
# LOG_MAX_BYTES=10485760
# LOG_BACKUP_COUNT=4

SLOT_OPEN_HOUR=9
SLOT_CLOSE_HOUR=17
SLOT_STEP_MINUTES=30

OLLAMA_BASE_URL=http://127.0.0.1:11434
# Default below balances accuracy vs VRAM/time for planner JSON — see README "LLM model choice"
OLLAMA_MODEL=qwen2.5:7b-instruct
# Optional: different Ollama tags per agent pass (defaults to OLLAMA_MODEL each). Example: faster planner JSON + quality finalize.
# OLLAMA_PLANNER_MODEL=qwen2.5:7b-instruct
# OLLAMA_FINALIZE_MODEL=qwen2.5:7b-instruct
OLLAMA_REQUEST_TIMEOUT_S=300
OLLAMA_INFER_DEVICE=auto
OLLAMA_NUM_GPU_LAYERS=-1
# OLLAMA_OPTIONS_JSON={"num_ctx":4096}

PIPER_BINARY=<REPO_ROOT>/.tools/piper/piper/piper
PIPER_VOICE=<REPO_ROOT>/.tools/piper/voices/en_US-lessac-low.onnx
PIPER_LD_LIBRARY_PATH=
PIPER_TIMEOUT_SEC=120
PIPER_CUDA=auto
PIPER_CUDA_STRATEGY=all
PIPER_CUDA_CPU_FALLBACK=1

CUDA_HOME=
CUDA_LIBRARY_PATH=

WHISPER_MODEL=base
WHISPER_DEVICE=auto
WHISPER_DEVICE_INDICES=
WHISPER_COMPUTE_TYPE=
WHISPER_BEAM_SIZE=5
# Strip silence via faster-whisper built-in VAD before decode (fewer hallucinations on noise). Default off for backward-compat timings.
# WHISPER_VAD_FILTER=1
WHISPER_NUM_WORKERS=
WHISPER_MAX_WORKERS=8
WHISPER_CPU_NUM_WORKERS=1

# --- LiveKit (optional; installs: pip install -r requirements-livekit.txt)
# Obtain key + secret from your LiveKit project or from local Docker startup logs —
# paste into `.env` only; do not commit. Use staging/prod credentials only in staging/prod.
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
# LIVEKIT_URL=ws://127.0.0.1:7880
# LIVEKIT_ROOM=healthcare-demo
# LIVEKIT_AGENT_IDENTITY=agent-worker
# LIVEKIT_AGENT_DATA_TOPIC=lk-agent-v1
