# =============================================================================
# Next.js base env (tracked). Override machine-specific URLs in `.env.local` (gitignored).
#
# SECURITY: NEXT_PUBLIC_* is inlined into client bundles — public. Never put secrets,
# API keys, or private tokens in any NEXT_PUBLIC_* variable.
# =============================================================================

# Browser uses this API origin — must match where uvicorn is reachable from the client.
NEXT_PUBLIC_API_URL=http://localhost:8000

# LiveKit signaling (local docker-compose often uses ws://127.0.0.1:7880). Set empty in `.env.local` to hide LiveKit for that checkout.
# Default voice transport on /call is WebSocket (better MuseTalk lipsync with local TTS). Set to 1 + LIVEKIT_URL to prefer LiveKit.
# NEXT_PUBLIC_PREFER_LIVEKIT_VOICE=1
# LiveKit + MuseTalk: optional tweak if avatar mouth lags RTC audio (default in app ~90ms).
# NEXT_PUBLIC_LIVEKIT_LIPSYNC_BIAS_MS=90
NEXT_PUBLIC_LIVEKIT_URL=ws://127.0.0.1:7880

# See backend/.env for MUSETALK_* (GPU pool, MUSETALK_BATCH_SIZE, MUSETALK_X264_*), LiveKit worker tuning
# (VOICE_LIVEKIT_VAD_*, VOICE_WORKER_LIPSYNC, VOICE_LIPSYNC_BEFORE_ROOM_AUDIO, VOICE_TTS_UI_CHUNK_BYTES), and segmented TTS:
# VOICE_TTS_SEGMENTED, VOICE_TTS_MAX_SEGMENT_CHARS (LiveKit only; WebSocket /process uses one WAV per turn).
NEXT_PUBLIC_MUSETALK_ENABLED=1
# Empty = same host as NEXT_PUBLIC_API_URL (POST /avatar/lipsync on main API; API proxies when MUSETALK_SERVICE_URL is set).
NEXT_PUBLIC_MUSETALK_API_URL=
# NEXT_PUBLIC_LIVEKIT_AGENT_WAIT_MS=60000
