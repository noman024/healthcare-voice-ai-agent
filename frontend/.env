# =============================================================================
# Next.js base env (tracked). Override machine-specific URLs in `.env.local` (gitignored).
#
# SECURITY: NEXT_PUBLIC_* is inlined into client bundles — public. Never put secrets,
# API keys, or private tokens in any NEXT_PUBLIC_* variable.
# =============================================================================

# Browser uses this API origin — must match where uvicorn is reachable from the client.
NEXT_PUBLIC_API_URL=http://localhost:8000

# LiveKit signaling (local docker-compose often uses ws://127.0.0.1:7880). Set empty in `.env.local` to hide LiveKit for that checkout.
NEXT_PUBLIC_LIVEKIT_URL=ws://127.0.0.1:7880

# Default room label in the LiveKit panel (override in .env.local per machine).
NEXT_PUBLIC_LIVEKIT_DEFAULT_ROOM=healthcare-demo

# Worker wait before WS voice fallback (ms). Uncomment to override built-in default.
# NEXT_PUBLIC_LIVEKIT_AGENT_WAIT_MS=60000
