# =============================================================================
# Next.js base env (tracked). Override machine-specific URLs in `.env.local` (gitignored).
#
# SECURITY: NEXT_PUBLIC_* is inlined into client bundles — public. Never put secrets,
# API keys, or private tokens in any NEXT_PUBLIC_* variable.
# =============================================================================

# Browser uses this API origin — must match where uvicorn is reachable from the client.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional WebRTC: ws:// or wss:// LiveKit URL (empty hides LiveKit UI until set).
NEXT_PUBLIC_LIVEKIT_URL=

# Must match backend LIVEKIT_AGENT_DATA_TOPIC when using LiveKit agent data channel
NEXT_PUBLIC_LIVEKIT_AGENT_TOPIC=lk-agent-v1
