# =============================================================================
# Copy to `.env.local` (gitignored). Values here override the same keys in tracked `frontend/.env`.
# Restart `npm run dev` after edits — `NEXT_PUBLIC_*` is inlined at build/start.
#
# SECURITY:
#   • NEXT_PUBLIC_* is bundled into browser JS — public only. Never put secrets,
#     private API keys, or credentials in NEXT_PUBLIC_*.
# =============================================================================

# API origin the browser calls. Leave empty to use the same host as the page (needed when you only tunnel :3000;
# Next.js rewrites proxy these paths to FastAPI on 127.0.0.1:8000). For classic dev, set this to http://localhost:8000.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Override ngrok local API (default http://127.0.0.1:4040/api/tunnels) if you use a non-default agent port.
# NGROK_LOCAL_API_URL=http://127.0.0.1:4040/api/tunnels

# LiveKit signaling (ws:// / wss://). Comment out for internet demos—remote clients cannot reach localhost LiveKit.
# Voice on /call defaults to WebSocket unless NEXT_PUBLIC_PREFER_LIVEKIT_VOICE=1. Worker: `backend/scripts/run_voice_worker.py`.
NEXT_PUBLIC_LIVEKIT_URL=ws://127.0.0.1:7880

# `/call` default room label — match the room you join for the worker
NEXT_PUBLIC_LIVEKIT_DEFAULT_ROOM=healthcare-demo

# 1 = MuseTalk MP4 lipsync on /call. Backend: MUSETALK_ENABLED + MUSETALK_SERVICE_URL + run service on :8001 (see README).
# Restart dev after changing. Put these in .env.local so they are never missing when that file exists.
NEXT_PUBLIC_MUSETALK_ENABLED=1
# Strongly recommended: same origin as NEXT_PUBLIC_API_URL (browser → :8000 /avatar/lipsync → proxies to :8001).
NEXT_PUBLIC_MUSETALK_API_URL=http://localhost:8000
# Only if you must hit the MuseTalk process directly (then ensure CORS_ORIGINS in backend/.env includes your dev origin):
# NEXT_PUBLIC_MUSETALK_API_URL=http://127.0.0.1:8001
# MuseTalk GPU pool and inference tuning live in backend/.env (e.g. MUSETALK_GPU_IDS, MUSETALK_BATCH_SIZE, MUSETALK_X264_PRESET).

# Backend: set **VOICE_PUBLISH_SAMPLE_RATE** (default 24000) in backend/.env for correct Piper playback speed.

# --- Parity with backend/.env (LiveKit worker; not read by Next.js)
# VOICE_TTS_SEGMENTED=1       # optional: chunked TTS+MuseTalk (may gap lipsync); omit + VOICE_WORKER_LIPSYNC=1 → one clip/utterance (backend default)
# VOICE_TTS_MAX_SEGMENT_CHARS=180
# VOICE_WORKER_LIPSYNC=1       # worker POSTs /avatar/lipsync; MP4 chunks on ``va`` (matches NEXT_PUBLIC_MUSETALK_*)
# VOICE_LIPSYNC_BEFORE_ROOM_AUDIO=1  # see backend/.env.example (default 1 = MP4 before room PCM when worker lipsync on)
# VOICE_API_BASE=http://127.0.0.1:8000
# WebSocket voice (/ws/conversation_audio) uses a single ``done.audio_wav_base64`` + browser lipsync POST (no segmentation).

# Debug the same flows as the UI without the browser:
#   cd backend && . .venv/bin/activate && python scripts/simulate_lipsync_paths.py --help

# 1 = when NEXT_PUBLIC_LIVEKIT_URL is set and /livekit/status OK, use LiveKit worker voice (default is WebSocket for /call).
# NEXT_PUBLIC_PREFER_LIVEKIT_VOICE=1

# Wait ms before WebSocket voice fallback if no agent (default 60000; min ~25s in app logic).
# NEXT_PUBLIC_LIVEKIT_AGENT_WAIT_MS=90000

# 1 = Web Audio mix path for remote playback (SDK default false; rarely needed).
# NEXT_PUBLIC_LIVEKIT_WEB_AUDIO_MIX=1

# 1 = [LiveKit DIAG] logs in DevTools console (subscribe/attach/startAudio).
# NEXT_PUBLIC_LIVEKIT_DIAG=1

# LiveKit-only: pull MuseTalk sync clock earlier by this many ms if lipsync looks behind room TTS (default 90; try 40–140).
# NEXT_PUBLIC_LIVEKIT_LIPSYNC_BIAS_MS=90
