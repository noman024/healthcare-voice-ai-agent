# =============================================================================
# Copy to `.env.local` (gitignored). Overrides tracked `frontend/.env`.
#
# SECURITY:
#   • NEXT_PUBLIC_* is bundled into browser JS — public only. Never put secrets,
#     private API keys, or credentials in NEXT_PUBLIC_*.
# =============================================================================

# API origin the browser calls (must be reachable from the user’s machine)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional LiveKit signaling (ws:// or wss://). Empty string hides the LiveKit panel until set
NEXT_PUBLIC_LIVEKIT_URL=ws://127.0.0.1:7880

# Data topic for optional LiveKit agent bridge — must match backend LIVEKIT_AGENT_DATA_TOPIC
NEXT_PUBLIC_LIVEKIT_AGENT_TOPIC=lk-agent-v1
