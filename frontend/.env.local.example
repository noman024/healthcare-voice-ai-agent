# =============================================================================
# Copy to `.env.local` (gitignored). Overrides tracked `frontend/.env`.
#
# SECURITY:
#   • NEXT_PUBLIC_* is bundled into browser JS — public only. Never put secrets,
#     private API keys, or credentials in NEXT_PUBLIC_*.
# =============================================================================

# API origin the browser calls (must be reachable from the user’s machine)
NEXT_PUBLIC_API_URL=http://localhost:8000

# LiveKit signaling (ws:// / wss://). Empty disables LiveKit in the UI. Worker: `backend/scripts/run_voice_worker.py`.
NEXT_PUBLIC_LIVEKIT_URL=ws://127.0.0.1:7880

# `/call` default room label — match the room you join for the worker
NEXT_PUBLIC_LIVEKIT_DEFAULT_ROOM=healthcare-demo

# Backend: set **VOICE_PUBLISH_SAMPLE_RATE** (default 24000) in backend/.env for correct Piper playback speed.

# Wait ms before WebSocket voice fallback if no agent (default 60000; min ~25s in app logic).
# NEXT_PUBLIC_LIVEKIT_AGENT_WAIT_MS=90000

# 1 = Web Audio mix path for remote playback (SDK default false; rarely needed).
# NEXT_PUBLIC_LIVEKIT_WEB_AUDIO_MIX=1

# 1 = [LiveKit DIAG] logs in DevTools console (subscribe/attach/startAudio).
# NEXT_PUBLIC_LIVEKIT_DIAG=1
