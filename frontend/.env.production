# =============================================================================
# Production build (`npm run build` / `npm start`) inlines NEXT_PUBLIC_* into the client.
#
# SECURITY: Use only public URLs here. Private keys and LiveKit secrets belong in the
# backend `.env` (never in NEXT_PUBLIC_*). Point this file at your real public API/LiveKit
# origins after deploy; keep sensitive values out of git — use CI secrets or server env.
# =============================================================================

NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

NEXT_PUBLIC_LIVEKIT_URL=

NEXT_PUBLIC_LIVEKIT_AGENT_TOPIC=lk-agent-v1
